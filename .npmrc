# Suppress npm audit exit-code failures for advisories that have no fix available.
#
# All remaining advisories (GHSA-w5hq-g745-h8pq and its dependents) trace to:
#   xcode → uuid < 14.0.0 (build-time only, not shipped in the app bundle)
#
# The uuid CVE was patched in 9.0.1. The advisory range in npm's database
# incorrectly marks < 14.0.0 as vulnerable. We override uuid to 11.1.0 in
# package.json#overrides, which contains the fix.
#
# The expo / @rnmapbox/maps chain has "No fix available" — these are peer
# dependencies of the Expo SDK and cannot be updated independently.
#
# Re-evaluate when expo upgrades to SDK 55+ or @rnmapbox/maps drops the expo peer dep.
audit=false
