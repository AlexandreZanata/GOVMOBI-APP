# GovMobile — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to source control.

# REST API base URL
# Development: http://172.19.2.116:3000
# Staging/Production: https://api.govmobile.gov.br
API_URL=http://172.19.2.116:3000

# WebSocket base URL
WS_URL=ws://172.19.2.116:3000

# Environment name (development | staging | production)
APP_ENV=development

# Enable mock facades (true = no real network calls, false = hit real API)
MOCK_MODE=false
