# GovMobile — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to source control.

# REST API base URL
API_URL=https://api.govmobile.dev

# WebSocket base URL
WS_URL=wss://ws.govmobile.dev

# Environment name (development | staging | production)
APP_ENV=development

# Enable mock facades (true = no real network calls)
MOCK_MODE=true
