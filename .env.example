# Sorrimobi — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to source control.

# REST API base URL
# Development: http://172.19.2.116:3000
# Staging/Production: https://api.govmobile.gov.br
API_URL=http://172.19.2.116:3000

# WebSocket base URL
# Socket.io uses HTTP for the initial handshake — use http:// not ws://
WS_URL=http://172.19.2.116:3000

# Environment name (development | staging | production)
APP_ENV=development

# Enable mock facades (true = no real network calls, false = hit real API)
MOCK_MODE=false

# Mapbox public access token (get from https://account.mapbox.com)
MAPBOX_ACCESS_TOKEN=

# Mapbox secret token (for downloads, optional)
MAPBOX_SECRET_TOKEN=

# OneSignal App ID for push notifications
ONESIGNAL_APP_ID=d6247b88-6e87-4695-ac0f-396993ede8ba
