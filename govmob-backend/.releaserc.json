{
  "branches": [
    "main",
    {
      "name": "beta",
      "prerelease": true
    },
    {
      "name": "alpha",
      "prerelease": true
    }
  ],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            { "type": "feat", "section": "✨ NOVIDADES" },
            { "type": "fix", "section": "🐛 CORREÇÕES" },
            { "type": "perf", "section": "⚡ PERFORMANCE" },
            { "type": "deprecated", "section": "👎 DEPRECIADO" },
            { "type": "removed", "section": "🚧 REMOVIDO" },
            { "type": "docs", "section": "📚 DOCUMENTAÇÃO" },
            { "type": "style", "section": "🎨 ESTILO" },
            { "type": "refactor", "section": "♻️ REFACTOR" },
            { "type": "test", "section": "🧪 TESTES" },
            { "type": "build", "section": "🔧 BUILD" },
            { "type": "ci", "section": "🚀 CI/CD" },
            { "type": "chore", "section": "📦 OUTROS" }
          ]
        },
        "releaseRules": [
          { "breaking": true, "release": "major" },
          { "revert": true, "release": "patch" },
          { "type": "feat", "release": "minor" },
          { "type": "fix", "release": "patch" },
          { "type": "perf", "release": "patch" },
          { "type": "deprecated", "release": "minor" },
          { "type": "removed", "release": "major" },
          { "type": "docs", "release": "patch" },
          { "type": "style", "release": "patch" },
          { "type": "refactor", "release": "patch" },
          { "type": "test", "release": false },
          { "type": "lint", "release": false },
          { "type": "build", "release": "patch" },
          { "type": "ci", "release": "patch" },
          { "type": "chore", "release": false }
        ]
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            { "type": "feat", "section": "✨ NOVIDADES" },
            { "type": "fix", "section": "🐛 CORREÇÕES" },
            { "type": "perf", "section": "⚡ PERFORMANCE" },
            { "type": "deprecated", "section": "👎 DEPRECIADO" },
            { "type": "removed", "section": "🚧 REMOVIDO" },
            { "type": "docs", "section": "📚 DOCUMENTAÇÃO" },
            { "type": "style", "section": "🎨 ESTILO" },
            { "type": "refactor", "section": "♻️ REFACTOR" },
            { "type": "test", "section": "🧪 TESTES" },
            { "type": "build", "section": "🔧 BUILD" },
            { "type": "ci", "section": "🚀 CI/CD" },
            { "type": "chore", "section": "📦 OUTROS" }
          ],
          "noteKeywords": ["BREAKING CHANGE", "BREAKING CHANGES", "BREAKING"]
        },
        "writerOpts": {
          "commitsSort": ["scope", "subject"],
          "groupBy": "section"
        }
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md",
        "changelogTitle": "# 📋 Changelog\n\nTodas as mudanças notáveis neste projeto."
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [],
        "successComment": ":rocket: Esta release está disponível em {{repoUrl}}/releases/tag/v${nextRelease.version}",
        "failComment": false,
        "failTitle": false,
        "labels": false,
        "releasedLabels": false
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["package.json", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ],
  "tagFormat": "${version}"
}
