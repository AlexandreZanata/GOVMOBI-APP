{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "maxWorkers": 1,
  "transformIgnorePatterns": [
    "node_modules/(?!uuid)"
  ],
  "moduleNameMapper": {
    "^uuid$": "<rootDir>/__mocks__/uuid.cjs"
  }
}
