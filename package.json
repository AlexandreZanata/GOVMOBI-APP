{
  "name": "govmobile",
  "version": "1.0.0",
  "description": "Public Administration Mobile App",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "emulator": "bash scripts/emulator.sh",
    "emulator:install": "cd android && ./gradlew assembleDebug && cd .. && adb -s emulator-5554 install -r android/app/build/outputs/apk/debug/aaaaaaaaa.apk && adb -s emulator-5554 reverse tcp:8081 tcp:8081 && adb -s emulator-5554 shell am start -n gov.govmobile.app/.MainActivity",
    "web": "expo start --web",
    "dev:android": "expo run:android",
    "dev:android:standalone": "cd android && ./gradlew assembleDebugStandalone",
    "dev:ios": "expo run:ios",
    "build:dev:android": "eas build --profile development --platform android",
    "build:dev:ios": "eas build --profile development --platform ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --watchAll=false --coverage",
    "guard:tests": "bash ./scripts/run-tests-ci.sh",
    "guard:changed": "bash ./scripts/guard-changed.sh",
    "guard:all": "bash ./scripts/guard-all.sh",
    "guard:strict": "bash ./scripts/guard-strict.sh",
    "guard:install-hook": "bash ./scripts/install-pre-push-hook.sh",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "build:android": "expo build:android",
    "build:ios": "expo build:ios",
    "build:web": "expo build:web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "@react-navigation/stack": "^6.3.20",
    "@reduxjs/toolkit": "^2.0.1",
    "@rnmapbox/maps": "^10.3.0",
    "axios": "^1.6.2",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-keep-awake": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "i18next": "^23.7.6",
    "onesignal-expo-plugin": "^2.4.0",
    "react": "19.1.0",
    "react-i18next": "^13.5.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-onesignal": "^5.4.3",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.0.4",
    "redux-persist": "^6.0.0",
    "socket.io-client": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.8",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "babel-jest": "^29.6.3",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "fast-check": "^4.7.0",
    "jest": "^29.6.3",
    "prettier": "^3.1.0",
    "react-native-testing-library": "^6.0.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "uuid": "^11.1.0"
  },
  "keywords": [
    "react-native",
    "typescript",
    "government",
    "public-administration",
    "mobile-app"
  ],
  "author": "GovMobile Team",
  "license": "MIT"
}
